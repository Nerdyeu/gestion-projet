generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model SamsaraConfig {
  id        Int      @id @default(autoincrement())
  apiToken  String
  region    String   @default("US") // US ou EU
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
